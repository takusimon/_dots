/* Frosted Glass Matugen Wlogout */

@import 'colors.css';

window {
    font-family: "Fira Code Medium";
    font-size: 16pt;

    color: #ffffff;

    /* transparent overlay */
    background-color: alpha(@background, 0.18);

    /* soft fullscreen blur */
    backdrop-filter: blur(32px);
}

/* -----------------------------------------------------
 * Buttons
 * ----------------------------------------------------- */

button {
    background-repeat: no-repeat;
    background-position: center;
    background-size: 26%;

    /* glass effect */
    background-color: alpha(@background, 0.28);

    /* keep text/icons white */
    color: #ffffff;

    border: 1px solid alpha(#ffffff, 0.10);

    border-radius: 28px;

    margin: 14px;
    padding: 18px;

    transition:
        background-size 0.25s ease,
        background-color 0.25s ease,
        border-color 0.25s ease,
        box-shadow 0.25s ease,
        transform 0.20s ease;

    /* frosted glass depth */
    box-shadow:
        inset 0 1px 0 alpha(#ffffff, 0.05),
        0 8px 24px alpha(#000000, 0.28);

    backdrop-filter: blur(24px);

    -gtk-icon-effect: none;
}

/* -----------------------------------------------------
 * Focus
 * ----------------------------------------------------- */

button:focus {
    outline: none;

    background-color: alpha(@background, 0.38);

    border-color: alpha(@primary, 0.35);

    box-shadow:
        inset 0 1px 0 alpha(#ffffff, 0.08),
        0 8px 28px alpha(#000000, 0.32),
        0 0 0 2px alpha(@primary, 0.10);
}

/* -----------------------------------------------------
 * Hover
 * ----------------------------------------------------- */

button:hover {
    background-size: 48%;

    /* autogenerated accent */
    background-color: @primary;

    /* dark icon/text like screenshot */
    color: #111111;

    border-color: transparent;

    transform: translateY(-2px);

    box-shadow:
        0 12px 32px alpha(@primary, 0.28),
        0 8px 24px alpha(#000000, 0.24);

    transition:
        background-size 0.25s cubic-bezier(.55, 0.0, .28, 1.682),
        background-color 0.25s ease,
        box-shadow 0.25s ease,
        transform 0.20s ease;
}

/* -----------------------------------------------------
 * Active
 * ----------------------------------------------------- */

button:active {
    background-color: @primary_fixed_dim;

    color: #111111;

    box-shadow:
        inset 0 2px 10px alpha(#000000, 0.22),
        0 4px 14px alpha(#000000, 0.22);
}

